<Window x:Class="CurrencyExchange.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Döviz Bürosu - Giriş" Height="350" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Background="#F0F2F5">
        <StackPanel Margin="40" VerticalAlignment="Center">
            <TextBlock Text="DÖVİZ BÜROSU SİSTEMİ" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#333"/>

            <TextBlock Text="Kullanıcı Adı:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtUsername" Height="30" Padding="5" Margin="0,0,0,10"/>

            <TextBlock Text="Şifre:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="30" Padding="5" Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnLogin" Content="Giriş Yap" Height="35" Background="#0078D7" Foreground="White" FontWeight="Bold" Grid.Column="0" Click="btnLogin_Click"/>
                <Button x:Name="btnRegister" Content="Kayıt Ol" Height="35" Background="#28A745" Foreground="White" FontWeight="Bold" Grid.Column="2" Click="btnRegister_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>