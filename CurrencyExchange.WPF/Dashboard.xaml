<Window x:Class="CurrencyExchange.WPF.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Döviz Bürosu - Kontrol Paneli" Height="600" Width="850" WindowStartupLocation="CenterScreen">
    <Grid Background="#F8F9FA" Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Cüzdan Bakiyesi: " FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtBalance" Text="0.00 PLN" FontSize="22" Foreground="#28A745" FontWeight="Bold" Margin="0,0,20,0" VerticalAlignment="Center"/>
                <Button x:Name="btnTopUp" Content="Para Yükle" Width="120" Height="35" Background="#FFC107" FontWeight="Bold" Click="btnTopUp_Click"/>
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Güncel Kurlar (NBP API)" Margin="0,0,10,10" FontWeight="Bold" FontSize="14">
            <DataGrid x:Name="dgRates" AutoGenerateColumns="True" IsReadOnly="True" Margin="5" FontWeight="Normal"/>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="1" Header="Döviz Al / Sat" Margin="10,0,0,10" FontWeight="Bold" FontSize="14">
            <StackPanel Margin="15">
                <TextBlock Text="Döviz Kodu (Örn: USD, EUR):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtCurrencyCode" Height="30" Padding="5" CharacterCasing="Upper" Margin="0,0,0,15"/>

                <TextBlock Text="Miktar:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtAmount" Height="30" Padding="5" Margin="0,0,0,25"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnBuy" Content="DÖVİZ AL (BUY)" Background="#0078D7" Foreground="White" Height="40" FontWeight="Bold" Grid.Column="0" Click="btnBuy_Click"/>
                    <Button x:Name="btnSell" Content="DÖVİZ SAT (SELL)" Background="#DC3545" Foreground="White" Height="40" FontWeight="Bold" Grid.Column="2" Click="btnSell_Click"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Grid.ColumnSpan="2" Header="İşlem Geçmişi" Margin="0,10,0,0" FontWeight="Bold" FontSize="14">
            <DataGrid x:Name="dgHistory" AutoGenerateColumns="True" IsReadOnly="True" Margin="5" FontWeight="Normal"/>
        </GroupBox>
    </Grid>
</Window>